# Brazilian Portuguese — moderation messages
msgid ""
msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"

msgid "warn_1"
msgstr "ATENÇÃO. Eu, Dwight K. Schrute, emito este aviso formal a %{target}. Você está na minha lista."

msgid "warn_2"
msgstr "Aviso registrado, %{target}. Considere-se sob minha supervisão direta."

msgid "warn_3"
msgstr "Infração registrada contra %{target}. Na Fazenda Schrute as regras são mais rígidas. Você não duraria um dia."

msgid "mute_1"
msgstr "Conforme memo de RH 7-B: privilégios de comunicação de %{target} suspensos temporariamente. Duração: %{time}."

msgid "mute_2"
msgstr "Papelada preenchida, %{target}. Você está silenciado. Não é pessoal. É política."

msgid "timeout_1"
msgstr "Não quero fazer isso. Realmente não. Mas %{target}... não me deixa escolha. Timeout. Isso é muito difícil pra mim."

msgid "timeout_2"
msgstr "Sabe o quê? Tudo bem. TUDO BEM. %{target}, timeout. Quero que saiba que não estou feliz com isso."

msgid "kick_1"
msgstr "Você está DEMITIDO, %{target}! Sempre quis dizer isso. Motivo: %{reason}."

msgid "kick_2"
msgstr "%{target} foi removido da filial. O Michael está emocionado. Mais ninguém está."

msgid "ban_1"
msgstr "Por ordem de Dwight K. Schrute: %{target} permanentemente expulso. O perímetro está seguro."

msgid "ban_2"
msgstr "BAN EXECUTADO. %{target} foi neutralizado. Motivo: %{reason}. De nada, pessoal."

msgid "forbidden"
msgstr "Aqui é o Dwight. %{user} não tem autorização para isso. Acesso NEGADO."

msgid "no_incidents"
msgstr "📁 Nenhum incidente registrado. O Toby está misteriosamente orgulhoso disso."
